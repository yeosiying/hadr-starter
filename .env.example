# Copy to .env and fill in. .env is gitignored.

# --- Web app (ADR-0013): visit http://HOST:PORT to see current alerts ---
HADR_WEB_HOST=127.0.0.1
HADR_WEB_PORT=8000

# --- Storage (ADR-0006) ---
HADR_DB_PATH=data/hadr.sqlite3
HADR_ARCHIVE_DIR=data/raw

# Static snapshot written by `hadr dashboard` (committed README artifact).
HADR_DASHBOARD_PATH=dashboard.html

# --- Feeds (ADR-0005) ---
HADR_USGS_FEED_URL=https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/all_day.geojson
HADR_USGS_POLL_SECONDS=60
HADR_GDACS_FEED_URL=https://www.gdacs.org/gdacsapi/api/events/geteventlist/EVENTS4APP
HADR_GDACS_POLL_SECONDS=360

# ReliefWeb enrichment (ADR-0014). Uses the public RSS feed — no approval
# needed. Set HADR_RELIEFWEB_APPNAME later to upgrade to the JSON API.
HADR_RELIEFWEB_ENABLED=true
HADR_RELIEFWEB_RSS_URL=https://reliefweb.int/disasters/rss.xml
HADR_RELIEFWEB_POLL_SECONDS=1800
HADR_RELIEFWEB_APPNAME=

# --- Tunables (ADR-0001, 0003, 0004, 0009) ---
HADR_PROVISIONAL_MAG_MIN=6.0
HADR_COALESCE_MINUTES=30
HADR_BACKFILL_HOURS=72
HADR_DEDUP_WINDOW_HOURS=48
HADR_DEDUP_MAX_KM=100
